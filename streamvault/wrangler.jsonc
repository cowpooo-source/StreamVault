{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "streamvault",
  "compatibility_date": "2025-09-27",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "kv_namespaces": [
    { "binding": "SV_SESSIONS", "id": "PLACEHOLDER_KV_ID" }
  ]
}
